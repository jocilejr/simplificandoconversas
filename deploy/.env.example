# ─── Domínios (obrigatório) ───
APP_DOMAIN=app.seudominio.com
API_DOMAIN=api.seudominio.com

# ─── Secrets (gerados automaticamente pelo install.sh) ───
POSTGRES_PASSWORD=change_me_strong_password
JWT_SECRET=change_me_jwt_secret_min_32_chars_long
ANON_KEY=will_be_generated_by_install_sh
SERVICE_ROLE_KEY=will_be_generated_by_install_sh

# ─── Baileys ───
BAILEYS_API_KEY=baileys-local-key

# ─── Opcional ───
OPENAI_API_KEY=
