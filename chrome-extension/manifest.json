{
  "manifest_version": 3,
  "name": "Chatbot Interno Origem Viva",
  "version": "1.1.0",
  "description": "Gerencie fluxos de chatbot diretamente no WhatsApp Web",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["https://web.whatsapp.com/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js", "content-whatsapp.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": ["https://web.whatsapp.com/*"],
      "js": ["content-dashboard.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["icons/logo-ov.png"],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ]
}
